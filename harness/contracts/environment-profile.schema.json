{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oh-my-harness.dev/contracts/v2/environment-profile.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "kind",
    "id",
    "displayName",
    "selectedAgents",
    "packages",
    "capabilities",
    "platformConditions",
    "startupSync"
  ],
  "properties": {
    "$schema": {
      "const": "../contracts/environment-profile.schema.json"
    },
    "schemaVersion": {
      "const": "2.0.0"
    },
    "kind": {
      "const": "environment-profile"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "selectedAgents": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["claude-code", "opencode", "codex"]
      }
    },
    "packages": {
      "$ref": "#/$defs/packages"
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      }
    },
    "platformConditions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/platformCondition"
      }
    },
    "startupSync": {
      "$ref": "#/$defs/startupSync"
    }
  },
  "$defs": {
    "stableId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "packages": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "optional"],
      "properties": {
        "required": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/stableId"
          }
        },
        "optional": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/stableId"
          }
        }
      }
    },
    "platformCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform", "supported"],
      "properties": {
        "platform": {
          "enum": [
            "darwin-arm64",
            "darwin-x64",
            "linux-arm64",
            "linux-x64",
            "win32-arm64",
            "win32-x64"
          ]
        },
        "supported": {
          "type": "boolean"
        },
        "guidance": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "startupSync": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "repairPinned",
        "addReviewedContent",
        "allowUpgrades",
        "allowRemovals"
      ],
      "properties": {
        "mode": {
          "const": "approved-additive"
        },
        "repairPinned": {
          "type": "boolean"
        },
        "addReviewedContent": {
          "type": "boolean"
        },
        "allowUpgrades": {
          "const": false
        },
        "allowRemovals": {
          "const": false
        }
      }
    }
  }
}
