{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zzanghyunmoo/oh-my-harness/blob/main/harness/contracts/conformance-result.schema.json",
  "title": "Oh My Harness conformance result",
  "description": "Tier-local terminal outcome with fail-closed pass accounting and complete evidence identity.",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "cell", "tier", "terminalStatus", "countsAsPass", "terminalReason", "execution", "evidenceIdentity", "artifacts", "reproduction"],
  "properties": {
    "$schema": { "const": "../contracts/conformance-result.schema.json" },
    "schemaVersion": { "const": "1.0.0" },
    "cell": { "$ref": "#/$defs/cell" },
    "tier": { "type": "string", "enum": ["hermetic", "personal", "hosted"] },
    "terminalStatus": { "$ref": "#/$defs/terminalStatus" },
    "countsAsPass": { "type": "boolean" },
    "terminalReason": { "type": "string", "minLength": 1 },
    "execution": { "$ref": "#/$defs/execution" },
    "evidenceIdentity": { "$ref": "#/$defs/evidenceIdentity" },
    "artifacts": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/artifact" }, "uniqueItems": true },
    "reproduction": { "$ref": "#/$defs/reproduction" },
    "certification": { "$ref": "#/$defs/certification" }
  },
  "allOf": [
    {
      "if": {
        "type": "object",
        "required": ["terminalStatus"],
        "properties": { "terminalStatus": { "const": "passed" } }
      },
      "then": {
        "type": "object",
        "properties": { "countsAsPass": { "const": true } }
      },
      "else": {
        "type": "object",
        "properties": { "countsAsPass": { "const": false } }
      }
    },
    {
      "if": {
        "type": "object",
        "required": ["tier"],
        "properties": { "tier": { "const": "hosted" } }
      },
      "then": {
        "type": "object",
        "required": ["certification"],
        "properties": { "certification": { "$ref": "#/$defs/certification" } }
      },
      "else": {
        "type": "object",
        "properties": { "certification": { "const": null } }
      }
    }
  ],
  "$defs": {
    "stableId": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "terminalStatus": {
      "type": "string",
      "enum": ["passed", "failed", "blocked", "timeout", "cancelled", "infra-error", "not-run", "expired"]
    },
    "cell": {
      "type": "object", "additionalProperties": false,
      "required": ["profileId", "featureId", "runtimeId", "platformId", "attempt"],
      "properties": {
        "profileId": { "$ref": "#/$defs/stableId" },
        "featureId": { "$ref": "#/$defs/stableId" },
        "runtimeId": { "$ref": "#/$defs/stableId" },
        "platformId": { "$ref": "#/$defs/stableId" },
        "attempt": { "type": "integer", "minimum": 1 }
      }
    },
    "execution": {
      "type": "object", "additionalProperties": false,
      "required": ["runtimeVersion", "os", "architecture", "executableSha256", "acquisitionIdentity"],
      "properties": {
        "runtimeVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "os": { "type": "string", "enum": ["linux", "darwin"] },
        "architecture": { "type": "string", "enum": ["x64", "arm64"] },
        "executableSha256": { "$ref": "#/$defs/sha256" },
        "acquisitionIdentity": { "type": "string", "minLength": 1 }
      }
    },
    "evidenceIdentity": {
      "type": "object", "additionalProperties": false,
      "required": ["source", "runtime", "overlay", "featureContract", "fixture", "oracle", "provider", "coordinator"],
      "properties": {
        "source": { "$ref": "#/$defs/sha256" },
        "runtime": { "$ref": "#/$defs/sha256" },
        "overlay": { "$ref": "#/$defs/sha256" },
        "featureContract": { "$ref": "#/$defs/sha256" },
        "fixture": { "$ref": "#/$defs/sha256" },
        "oracle": { "$ref": "#/$defs/sha256" },
        "provider": { "$ref": "#/$defs/sha256" },
        "coordinator": { "$ref": "#/$defs/sha256" }
      }
    },
    "artifact": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "path", "sha256", "redacted"],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "path": { "type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "redacted": { "const": true }
      }
    },
    "reproduction": {
      "type": "object", "additionalProperties": false,
      "required": ["fixtureId", "argv", "workspaceSha256"],
      "properties": {
        "fixtureId": { "$ref": "#/$defs/stableId" },
        "argv": { "type": "array", "minItems": 1, "maxItems": 64, "items": { "type": "string", "minLength": 1 } },
        "workspaceSha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "certification": {
      "type": "object", "additionalProperties": false,
      "required": ["targetFingerprint", "expiresAt"],
      "properties": {
        "targetFingerprint": { "type": "string", "minLength": 1 },
        "expiresAt": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" }
      }
    }
  }
}
