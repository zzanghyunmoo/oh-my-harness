{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oh-my-harness.dev/contracts/v2/release-catalog.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "kind",
    "channel",
    "sequence",
    "catalogRevision",
    "compatibility",
    "artifacts"
  ],
  "properties": {
    "$schema": {
      "const": "../contracts/release-catalog.schema.json"
    },
    "schemaVersion": {
      "const": "2.0.0"
    },
    "kind": {
      "const": "release-catalog"
    },
    "channel": {
      "$ref": "#/$defs/stableId"
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "catalogRevision": {
      "$ref": "#/$defs/sha256"
    },
    "compatibility": {
      "$ref": "#/$defs/compatibility"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    }
  },
  "$defs": {
    "stableId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "channelPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "$schema",
        "schemaVersion",
        "kind",
        "id",
        "audience",
        "bootstrapTrust",
        "automaticAdditions",
        "requireExactDigest",
        "allowMutableReferences"
      ],
      "properties": {
        "$schema": {
          "const": "../contracts/release-catalog.schema.json#/$defs/channelPolicy"
        },
        "schemaVersion": {
          "const": "2.0.0"
        },
        "kind": {
          "const": "release-channel-policy"
        },
        "id": {
          "const": "stable"
        },
        "audience": {
          "const": "oh-my-harness-v2"
        },
        "bootstrapTrust": {
          "$ref": "#/$defs/bootstrapTrust"
        },
        "automaticAdditions": {
          "const": ["managed-skill"]
        },
        "requireExactDigest": {
          "const": true
        },
        "allowMutableReferences": {
          "const": false
        }
      }
    },
    "bootstrapTrust": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "sourceId"],
      "properties": {
        "kind": {
          "const": "embedded"
        },
        "sourceId": {
          "$ref": "#/$defs/stableId"
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimumCliVersion", "maximumCliVersion"],
      "properties": {
        "minimumCliVersion": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "maximumCliVersion": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "digest", "sourceId"],
      "properties": {
        "id": {
          "$ref": "#/$defs/stableId"
        },
        "kind": {
          "enum": ["catalog", "managed-skill", "plugin"]
        },
        "digest": {
          "$ref": "#/$defs/sha256"
        },
        "sourceId": {
          "$ref": "#/$defs/stableId"
        }
      }
    }
  }
}
