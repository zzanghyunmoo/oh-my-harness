{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oh-my-harness.dev/contracts/v2/apply-plan.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "kind",
    "catalogRevision",
    "desiredState",
    "platform",
    "observedState",
    "preflights",
    "actions",
    "digest"
  ],
  "properties": {
    "$schema": {
      "const": "../contracts/apply-plan.schema.json"
    },
    "schemaVersion": {
      "const": "2.0.0"
    },
    "kind": {
      "const": "apply-plan"
    },
    "catalogRevision": {
      "$ref": "#/$defs/sha256"
    },
    "desiredState": {
      "$ref": "#/$defs/desiredState"
    },
    "platform": {
      "$ref": "#/$defs/platform"
    },
    "observedState": {
      "type": "object",
      "additionalProperties": true
    },
    "preflights": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/preflight"
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action"
      }
    },
    "digest": {
      "$ref": "#/$defs/sha256"
    }
  },
  "$defs": {
    "stableId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*(?::[a-z][a-z0-9-]*)*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "desiredState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profileId", "selectedAgents"],
      "properties": {
        "profileId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "selectedAgents": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["claude-code", "opencode", "codex"]
          }
        }
      }
    },
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "arch"],
      "properties": {
        "os": {
          "enum": ["darwin", "linux", "win32"]
        },
        "arch": {
          "enum": ["arm64", "x64"]
        }
      }
    },
    "preflight": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "required", "status"],
      "properties": {
        "id": {
          "$ref": "#/$defs/stableId"
        },
        "required": {
          "type": "boolean"
        },
        "status": {
          "enum": ["ready", "optional-gap", "unsupported", "unverifiable"]
        },
        "detail": {
          "type": "string"
        }
      }
    },
    "preimage": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": {
              "const": "missing"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "sha256", "size"],
          "properties": {
            "kind": {
              "const": "file"
            },
            "sha256": {
              "$ref": "#/$defs/sha256"
            },
            "size": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      ]
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "required", "target", "preimage"],
      "properties": {
        "id": {
          "$ref": "#/$defs/stableId"
        },
        "kind": {
          "enum": ["acquire", "register", "write", "remove"]
        },
        "required": {
          "type": "boolean"
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "preimage": {
          "$ref": "#/$defs/preimage"
        },
        "payload": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
