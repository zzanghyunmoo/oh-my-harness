{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oh-my-harness.dev/contracts/v2/managed-state-receipt.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "kind",
    "catalogRevision",
    "planDigest",
    "appliedAt",
    "completedActionIds",
    "desiredState",
    "startupConsent",
    "runtimeReadiness",
    "ownership"
  ],
  "properties": {
    "$schema": {
      "const": "../contracts/managed-state-receipt.schema.json"
    },
    "schemaVersion": {
      "const": "2.0.0"
    },
    "kind": {
      "const": "managed-state-receipt"
    },
    "catalogRevision": {
      "$ref": "#/$defs/sha256"
    },
    "planDigest": {
      "$ref": "#/$defs/sha256"
    },
    "appliedAt": {
      "type": "string",
      "format": "date-time"
    },
    "completedActionIds": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/actionId"
      }
    },
    "desiredState": {
      "$ref": "#/$defs/desiredState"
    },
    "startupConsent": {
      "$ref": "#/$defs/startupConsent"
    },
    "runtimeReadiness": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/runtimeReadiness"
      }
    },
    "ownership": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ownership"
      }
    },
    "releaseChannels": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/stableId"
      },
      "additionalProperties": {
        "$ref": "#/$defs/releaseChannel"
      }
    }
  },
  "$defs": {
    "stableId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "actionId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*(?::[a-z][a-z0-9-]*)*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "agentId": {
      "enum": ["claude-code", "opencode", "codex"]
    },
    "desiredState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profileId", "selectedAgents"],
      "properties": {
        "profileId": {
          "$ref": "#/$defs/stableId"
        },
        "selectedAgents": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/agentId"
          }
        }
      }
    },
    "startupConsent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repairPinned",
        "addReviewedContent",
        "channelId",
        "profileId",
        "artifactClasses",
        "permissionScopes"
      ],
      "properties": {
        "repairPinned": {
          "type": "boolean"
        },
        "addReviewedContent": {
          "type": "boolean"
        },
        "channelId": {
          "$ref": "#/$defs/stableId"
        },
        "profileId": {
          "$ref": "#/$defs/stableId"
        },
        "artifactClasses": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "managed-skill",
              "plugin",
              "hook",
              "mcp-server",
              "lsp-binary",
              "external-command",
              "package-script"
            ]
          }
        },
        "permissionScopes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "runtimeReadiness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agentId", "state"],
      "properties": {
        "agentId": {
          "$ref": "#/$defs/agentId"
        },
        "state": {
          "enum": ["ready", "pending", "unsupported", "unverifiable"]
        }
      }
    },
    "ownership": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "target", "digest"],
      "properties": {
        "id": {
          "$ref": "#/$defs/actionId"
        },
        "kind": {
          "enum": ["file", "directory", "registration", "executable"]
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "releaseChannel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sequence", "manifestDigest"],
      "properties": {
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "manifestDigest": {
          "$ref": "#/$defs/sha256"
        }
      }
    }
  }
}
