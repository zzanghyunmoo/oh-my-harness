{
  "$schema": "./proxy-profiles.schema.json",
  "schemaVersion": "1.0.0",
  "defaultInstallProfiles": [
    "quotio",
    "ccs"
  ],
  "profiles": [
    {
      "id": "litellm",
      "label": "LiteLLM",
      "adapter": "openai-compatible",
      "toggleEnvVar": "ENABLE_LITELLM",
      "baseUrlEnvVar": "LITELLM_BASE_URL",
      "apiKeyEnvVar": "LITELLM_API_KEY",
      "modelsPath": "/models",
      "install": {
        "kind": "external",
        "guidance": "Deploy LiteLLM separately, issue a virtual key, then set LITELLM_BASE_URL and LITELLM_API_KEY locally."
      }
    },
    {
      "id": "quotio",
