{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "types": ["node"],
    "allowJs": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": ".tmp/workspace-connectors-test"
  },
  "include": [
    "extensions/workspace-connectors/**/*.ts",
    "extensions/workspace-cli-tools/**/*.ts",
    "extensions/setup-doctor/**/*.ts",
    "plugins/oh-my-harness/mcp/cli-tools-core.mjs"
  ]
}
