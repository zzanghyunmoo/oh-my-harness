{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zzanghyunmoo/oh-my-harness/blob/main/plugins/oh-my-harness/profiles/runtime-tools.schema.json",
  "title": "Oh My Harness runtime tool profiles",
  "description": "Secret-free issue tracker, wiki, and Git backend assignments consumed automatically by runtime adapters and omh setup.",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "profiles", "runtimes"],
  "properties": {
    "$schema": { "const": "./runtime-tools.schema.json" },
    "schemaVersion": { "const": "1.0.0" },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/profile" }
    },
    "runtimes": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": { "$ref": "#/$defs/runtime" }
    }
  },
  "$defs": {
    "stableId": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issue-tracker", "wiki", "git"],
      "properties": {
        "issue-tracker": { "enum": ["jira", "linear"] },
        "wiki": { "enum": ["confluence", "notion"] },
        "git": { "enum": ["github", "gitlab"] }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "bindings"],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "bindings": { "$ref": "#/$defs/bindings" }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtimeId", "profileId"],
      "properties": {
        "runtimeId": { "enum": ["claude-code", "codex", "opencode", "pi"] },
        "profileId": { "$ref": "#/$defs/stableId" }
      }
    }
  }
}
