{
  "name": "oh-my-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-runtime coding-agent harness with Pi compatibility surfaces.",
  "keywords": [
    "agent-harness",
    "pi-package"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "profile:verify": "node scripts/profile-pack.mjs verify",
    "profile:lock": "node scripts/profile-pack.mjs lock --write",
    "profile:apply": "node scripts/profile-pack.mjs apply",
    "test:harness": "node --test tests/harness/*.test.mjs",
    "harness:descriptors:verify": "node scripts/harness/descriptors.mjs verify",
    "harness:upstream:generate": "node scripts/harness/upstream.mjs generate",
    "harness:upstream:verify": "node scripts/harness/upstream.mjs verify",
    "test:workspace-connectors": "node -e \"require('node:fs').rmSync('.tmp/workspace-connectors-test',{recursive:true,force:true})\" && tsc -p tsconfig.workspace-connectors-tests.json && node --test .tmp/workspace-connectors-test/extensions/workspace-connectors/*.test.js .tmp/workspace-connectors-test/extensions/setup-doctor/*.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.10",
    "@types/node": "^25.8.0",
    "tar-stream": "3.2.0",
    "typescript": "^6.0.3",
    "yauzl": "3.4.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "pi": {
    "extensions": [
      "./extensions/env-loader",
      "./extensions/quotio-provider",
      "./extensions/workspace-connectors",
      "./extensions/setup-doctor"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ],
    "themes": [
      "./themes"
    ]
  }
}
