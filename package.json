{
  "name": "oh-my-harness",
  "version": "0.2.0",
  "private": true,
  "description": "Cross-runtime coding-agent harness with a preview-first management CLI.",
  "keywords": [
    "agent-harness",
    "cli",
    "codex-plugin",
    "omh",
    "opencode-plugin",
    "pi-package"
  ],
  "type": "module",
  "main": ".opencode/plugins/oh-my-harness.js",
  "bin": {
    "oh-my-harness": "./omh",
    "omh": "./omh"
  },
  "files": [
    ".agents/plugins/marketplace.json",
    ".claude-plugin/marketplace.json",
    ".opencode/plugins/oh-my-harness.js",
    "bin/omh.mjs",
    "catalogs/",
    "dist/",
    "extensions/*.ts",
    "extensions/*/*.ts",
    "extensions/*/package.json",
    "extensions/*/package-lock.json",
    "!extensions/**/*.test.ts",
    "harness/",
    "omh",
    "omh.cmd",
    "plugins/",
    "schemas/",
    "scripts/"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "profile:verify": "node scripts/profile-pack.mjs verify",
    "profile:lock": "node scripts/profile-pack.mjs lock --write",
    "profile:apply": "node scripts/profile-pack.mjs apply",
    "omh": "npm run build --silent && node dist/cli/main.js",
    "test:unit": "npm run build --silent && node --test \"tests/unit/*.test.ts\"",
    "package:verify": "npm run build --silent && node --test \"tests/release/*.test.ts\"",
    "test:harness": "npm run build --silent && node --test \"tests/harness/*.test.mjs\"",
    "harness:descriptors:verify": "node scripts/harness/descriptors.mjs verify",
    "harness:install": "node scripts/harness/install.mjs",
    "proxies:install": "node scripts/proxies/manage.mjs install",
    "proxies:configure": "node scripts/proxies/manage.mjs configure",
    "proxies:doctor": "node scripts/proxies/manage.mjs doctor",
    "tools:install": "node scripts/tools/manage.mjs",
    "tools:doctor": "node scripts/tools/manage.mjs doctor",
    "harness:upstream:generate": "node scripts/harness/upstream.mjs generate",
    "harness:upstream:verify": "node scripts/harness/upstream.mjs verify",
    "test:workspace-connectors": "node -e \"require('node:fs').rmSync('.tmp/workspace-connectors-test',{recursive:true,force:true})\" && tsc -p tsconfig.workspace-connectors-tests.json && node -e \"require('node:fs').cpSync('plugins/oh-my-harness/profiles','.tmp/workspace-connectors-test/plugins/oh-my-harness/profiles',{recursive:true})\" && node --test .tmp/workspace-connectors-test/extensions/workspace-connectors/*.test.js .tmp/workspace-connectors-test/extensions/workspace-cli-tools/*.test.js .tmp/workspace-connectors-test/extensions/setup-doctor/*.test.js .tmp/workspace-connectors-test/extensions/provider-adapter-kit/*.test.js"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.18.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "jsonc-parser": "3.3.1",
    "tar-stream": "3.2.0",
    "typebox": "^1.1.38",
    "yauzl": "3.4.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.10",
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "pi": {
    "extensions": [
      "./extensions/env-loader",
      "./extensions/litellm-provider",
      "./extensions/quotio-provider",
      "./extensions/ccs-provider",
      "./extensions/workspace-connectors",
      "./extensions/workspace-cli-tools",
      "./extensions/setup-doctor"
    ],
    "skills": [
      "./plugins/oh-my-harness/skills"
    ],
    "prompts": [
      "./prompts"
    ],
    "themes": [
      "./themes"
    ]
  }
}
