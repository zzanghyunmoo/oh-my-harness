{
  "$schema": "./profile-pack.schema.json",
  "schemaVersion": "0.1.0",
  "id": "default",
  "displayName": "Default oh-my-harness",
  "description": "Base profile for installing oh-my-harness with the env loader, setup doctor, prompts, themes, and the recent pi-clear external package signal recorded as optional intent.",
  "packageRefs": [
    {
      "name": "oh-my-harness",
      "installSpec": "git:github.com/zzanghyunmoo/oh-my-harness",
      "source": "package-json",
      "required": true,
      "intent": "core-package",
      "notes": "Core package represented by this repository."
    },
    {
      "name": "pi-clear",
      "installSpec": "npm:pi-clear",
      "source": "manual-signal",
      "required": false,
      "intent": "recent-manual-signal",
      "notes": "Recent manual install signal: pi install npm:pi-clear. Recorded as reproducible intent only."
    }
  ],
  "piPackage": {
    "extensions": [
      "./extensions/env-loader",
      "./extensions/quotio-provider",
      "./extensions/workspace-connectors",
      "./extensions/workspace-cli-tools",
      "./extensions/setup-doctor"
    ],
    "prompts": [
      "./prompts"
    ],
    "themes": [
      "./themes"
    ],
    "skills": [
      "./plugins/oh-my-harness/skills"
    ]
  },
  "extensionToggles": [
    {
      "extensionId": "env-loader",
      "extensionPath": "./extensions/env-loader",
      "enabledByDefault": true,
      "notes": "Always loaded first through package.json Pi extension order."
    },
    {
      "extensionId": "setup-doctor",
      "extensionPath": "./extensions/setup-doctor",
      "enabledByDefault": true,
      "notes": "Provides /oh-my-harness and /oh-my-harness-doctor with legacy /oh-my-pi aliases."
    },
    {
      "extensionId": "quotio-provider",
      "extensionPath": "./extensions/quotio-provider",
      "enabledByDefault": false,
      "toggleEnvVar": "ENABLE_QUOTIO",
      "requiredValue": "not-true"
    },
    {
      "extensionId": "workspace-connectors",
      "extensionPath": "./extensions/workspace-connectors",
      "enabledByDefault": false,
      "toggleEnvVar": "ENABLE_WORKSPACE_CONNECTORS",
      "requiredValue": "not-true"
    },
    {
      "extensionId": "workspace-cli-tools",
      "extensionPath": "./extensions/workspace-cli-tools",
      "enabledByDefault": false,
      "toggleEnvVar": "ENABLE_WORKSPACE_CLI_TOOLS",
      "requiredValue": "not-true"
    }
  ],
  "secretRefs": [],
  "connectors": [],
  "providers": [],
  "metadataRefs": {
    "packageJson": "package.json",
    "secretBlueprint": "docs/blueprints/oh-my-harness.secret-blueprint.json",
    "capabilityRegistry": "extensions/capability-registry.ts",
    "connectorCatalog": "extensions/connector-backend-catalog.ts",
    "providerAdapterKit": "extensions/provider-adapter-kit/openai-compatible.ts"
  }
}
