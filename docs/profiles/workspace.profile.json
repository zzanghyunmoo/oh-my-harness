{
  "$schema": "./profile-pack.schema.json",
  "schemaVersion": "0.1.0",
  "id": "workspace",
  "displayName": "Workspace connectors",
  "description": "Profile for machines that should expose the role-scoped external CLI tool pack plus personal Linear/Notion OAuth, read-only GitHub/GitLab compatibility bridges, and staged hosted Jira/Confluence connector UX without committing auth state.",
  "extends": [
    "default"
  ],
  "packageRefs": [
    {
      "name": "oh-my-harness",
      "installSpec": "git:github.com/zzanghyunmoo/oh-my-harness",
      "source": "package-json",
      "required": true,
      "intent": "core-package"
    },
    {
      "name": "pi-web-access",
      "installSpec": "npm:pi-web-access",
      "source": "settings-example",
      "required": false,
      "intent": "external-pi-package",
      "notes": "Existing settings.example.json external package intent."
    },
    {
      "name": "super-pi",
      "installSpec": "npm:@leing2021/super-pi",
      "source": "settings-example",
      "required": false,
      "intent": "external-pi-package",
      "notes": "Existing settings.example.json external package intent."
    },
    {
      "name": "pi-clear",
      "installSpec": "npm:pi-clear",
      "source": "manual-signal",
      "required": false,
      "intent": "recent-manual-signal"
    }
  ],
  "piPackage": {
    "extensions": [
      "./extensions/env-loader",
      "./extensions/quotio-provider",
      "./extensions/workspace-connectors",
      "./extensions/workspace-cli-tools",
      "./extensions/setup-doctor"
    ],
    "prompts": [
      "./prompts"
    ],
    "themes": [
      "./themes"
    ],
    "skills": [
      "./plugins/oh-my-harness/skills"
    ]
  },
  "extensionToggles": [
    {
      "extensionId": "env-loader",
      "extensionPath": "./extensions/env-loader",
      "enabledByDefault": true
    },
    {
      "extensionId": "setup-doctor",
      "extensionPath": "./extensions/setup-doctor",
      "enabledByDefault": true
    },
    {
      "extensionId": "workspace-connectors",
      "extensionPath": "./extensions/workspace-connectors",
      "enabledByDefault": true,
      "toggleEnvVar": "ENABLE_WORKSPACE_CONNECTORS",
      "requiredValue": "true"
    },
    {
      "extensionId": "workspace-cli-tools",
      "extensionPath": "./extensions/workspace-cli-tools",
      "enabledByDefault": true,
      "toggleEnvVar": "ENABLE_WORKSPACE_CLI_TOOLS",
      "requiredValue": "true"
    },
    {
      "extensionId": "quotio-provider",
      "extensionPath": "./extensions/quotio-provider",
      "enabledByDefault": false,
      "toggleEnvVar": "ENABLE_QUOTIO",
      "requiredValue": "not-true"
    }
  ],
  "secretRefs": [
    {
      "name": "ENABLE_WORKSPACE_CLI_TOOLS",
      "kind": "toggle",
      "source": "docs/blueprints/oh-my-harness.secret-blueprint.json",
      "requiredWhen": "Use this profile on a Pi machine that should expose role-scoped external CLI tools.",
      "commitPolicy": "name-and-intent-only"
    },
    {
      "name": "ENABLE_WORKSPACE_CONNECTORS",
      "kind": "toggle",
      "source": "docs/blueprints/oh-my-harness.secret-blueprint.json",
      "requiredWhen": "Use this profile on a machine that should expose Linear/Notion connector commands and tools.",
      "commitPolicy": "name-and-intent-only"
    }
  ],
  "connectors": [
    {
      "id": "linear",
      "backendRef": "linear",
      "tenant": "personal",
      "capabilitySlot": "issue-tracker",
      "setupModes": [
        "full",
        "selective"
      ],
      "exposureState": "runtime-tool",
      "enabledByDefault": true,
      "auth": "oauth-state-local-only",
      "authOwnership": [
        "pi-oauth",
        "env-fallback"
      ],
      "statusCommand": "/connector-tools linear",
      "toolNames": [
        "workspace_mcp_list_tools",
        "workspace_mcp_call_tool"
      ],
      "loginCommand": "/connector-login linear"
    },
    {
      "id": "notion",
      "backendRef": "notion",
      "tenant": "personal",
      "capabilitySlot": "wiki",
      "setupModes": [
        "full",
        "selective"
      ],
      "exposureState": "runtime-tool",
      "enabledByDefault": true,
      "auth": "oauth-state-local-only",
      "authOwnership": [
        "pi-oauth",
        "env-fallback"
      ],
      "statusCommand": "/connector-tools notion",
      "toolNames": [
        "workspace_mcp_list_tools",
        "workspace_mcp_call_tool"
      ],
      "loginCommand": "/connector-login notion"
    },
    {
      "id": "github",
      "backendRef": "github",
      "tenant": "personal",
      "capabilitySlot": "git",
      "setupModes": [
        "full",
        "selective"
      ],
      "exposureState": "runtime-tool",
      "enabledByDefault": true,
      "auth": "local-gh-cli-session",
      "authOwnership": [
        "external-cli"
      ],
      "statusCommand": "gh auth status --hostname github.com",
      "toolNames": [
        "github_gh_cli"
      ]
    },
    {
      "id": "gitlab",
      "backendRef": "gitlab",
      "tenant": "company",
      "capabilitySlot": "git",
      "setupModes": [
        "full",
        "selective"
      ],
      "exposureState": "runtime-tool",
      "enabledByDefault": true,
      "auth": "local-glab-cli-session",
      "authOwnership": [
        "external-cli"
      ],
      "statusCommand": "glab auth status",
      "toolNames": [
        "gitlab_glab_cli"
      ]
    },
    {
      "id": "jira",
      "backendRef": "jira",
      "tenant": "company",
      "capabilitySlot": "issue-tracker",
      "setupModes": [
        "full",
        "selective"
      ],
      "exposureState": "runtime-gated",
      "enabledByDefault": true,
      "auth": "setup-visible-runtime-gated",
      "authOwnership": [
        "setup-only"
      ],
      "statusCommand": "/connector-setup full",
      "toolNames": []
    },
    {
      "id": "confluence",
      "backendRef": "confluence",
      "tenant": "company",
      "capabilitySlot": "wiki",
      "setupModes": [
        "full",
        "selective"
      ],
      "exposureState": "runtime-gated",
      "enabledByDefault": true,
      "auth": "setup-visible-runtime-gated",
      "authOwnership": [
        "setup-only"
      ],
      "statusCommand": "/connector-setup full",
      "toolNames": []
    }
  ],
  "providers": [],
  "metadataRefs": {
    "packageJson": "package.json",
    "secretBlueprint": "docs/blueprints/oh-my-harness.secret-blueprint.json",
    "capabilityRegistry": "extensions/capability-registry.ts",
    "connectorCatalog": "extensions/connector-backend-catalog.ts",
    "providerAdapterKit": "extensions/provider-adapter-kit/openai-compatible.ts"
  }
}
